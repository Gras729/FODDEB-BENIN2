{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/auth/:path*",       "destination": "/api/auth/index.js" },
    { "source": "/api/membres/:path*",    "destination": "/api/membres/index.js" },
    { "source": "/api/dons/:path*",       "destination": "/api/dons/index.js" },
    { "source": "/api/projets/:path*",    "destination": "/api/projets/index.js" },
    { "source": "/api/activites/:path*",  "destination": "/api/activites/index.js" },
    { "source": "/api/actualites/:path*", "destination": "/api/actualites/index.js" },
    { "source": "/api/newsletter/:path*", "destination": "/api/newsletter/index.js" },
    { "source": "/api/contacts/:path*",   "destination": "/api/contacts/index.js" },
    { "source": "/api/bailleurs/:path*",  "destination": "/api/bailleurs/index.js" },
    { "source": "/api/rapports/:path*",   "destination": "/api/rapports/index.js" },
    { "source": "/api/upload/:path*",     "destination": "/api/upload/index.js" },
    { "source": "/api/parametres/:path*", "destination": "/api/parametres/index.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
